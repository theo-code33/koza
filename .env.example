# Database — Prisma Postgres (hosted).
#
# Get your connection string by linking the database (writes DATABASE_URL here):
#   npx prisma postgres link --database <database-id>
# …or paste your Prisma Postgres connection string directly.
#
# Never commit the real .env — it is git-ignored. CI reads DATABASE_URL from a
# GitHub Actions secret.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
