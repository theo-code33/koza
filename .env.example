# PostgreSQL (used by docker-compose and Prisma)
POSTGRES_USER=koza
POSTGRES_PASSWORD=koza
POSTGRES_DB=koza

# Prisma connection string (host tools).
# The dev Postgres container is exposed on host port 5433 to avoid clashing
# with a local Postgres on 5432. Inside docker-compose the app uses db:5432.
DATABASE_URL="postgresql://koza:koza@localhost:5433/koza?schema=public"
